	<style name="TablaHeader" fontSize="11" isBold="true"/>
	<style name="TablaTexto" fontSize="10"/>
	<parameter name="id_tarea" class="java.lang.Long"/>
	<queryString>
		<![CDATA[SELECT 
            t.id AS tarea_id,
            t.nombre AS tarea_nombre,
            t.descripcion AS tarea_descripcion,
            t.fecha_ini,
            t.fecha_fin,

            j.id AS jornada_id,
            j.horas,
            j.fecha AS jornada_fecha,
            j.validado,

            tr.id AS trabajador_id,
            tr.nombre AS trabajador_nombre,
            tr.apellido AS trabajador_apellido

        FROM registro_jornada j
        JOIN Trabajadores tr ON tr.id = j.id_trabajador
        JOIN Tareas t ON t.id = j.id_tarea
        WHERE t.id = $P{id_tarea}
        ORDER BY j.fecha]]>
	</queryString>
	<field name="tarea_nombre" class="java.lang.String"/>
	<field name="tarea_descripcion" class="java.lang.String"/>
	<field name="fecha_ini" class="java.sql.Date"/>
	<field name="fecha_fin" class="java.sql.Date"/>
	<field name="jornada_fecha" class="java.sql.Date"/>
	<field name="horas" class="java.lang.Integer"/>
	<field name="validado" class="java.lang.Boolean"/>
	<field name="trabajador_nombre" class="java.lang.String"/>
	<field name="trabajador_apellido" class="java.lang.String"/>
